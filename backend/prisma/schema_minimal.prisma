generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Parish {
  id             Int              @id @default(autoincrement())
  nombre         String
  bautizos       Bautizo[]
}

model Bautizo {
  id                Int       @id @default(autoincrement())
  parishId          Int
  parish            Parish @relation(fields: [parishId], references: [id])
}
